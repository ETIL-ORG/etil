        penwidth=1 style="filled,rounded,dashed"];

    backref -> curr [style=dashed color="#E65100" penwidth=1.5 arrowhead=vee];
    prev -> curr [style=dotted color="#BBBBBB" penwidth=1.5 arrowhead=vee];
