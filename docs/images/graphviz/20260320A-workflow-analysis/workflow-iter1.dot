// ETIL Workflow — Iteration 1: MLP Feasibility
// v0.8.15 → v1.0.0 · Mar 10-18, 2026

digraph Iter1 {
    rankdir=TB;
    fontname="Helvetica Neue";
    fontsize=14;
    bgcolor="white";
    nodesep=0.8;
    ranksep=1.0;
    pad=0.6;

    node [
        fontname="Helvetica Neue"
        fontsize=11
        style="filled,rounded"
        shape=box
        penwidth=2
        margin="0.18,0.10"
    ];

    edge [
        fontname="Helvetica Neue"
        fontsize=9
    ];

    // Title
    title [
        label=<<font point-size="18"><b>Iteration 1: MLP Feasibility</b></font><br/><font point-size="11" color="#666666">v0.8.15 → v1.0.0 · Mar 10-18, 2026 · 17 C++ matrix primitives</font><br/><br/><font point-size="9" color="#999999">Can we build a neural network in ETIL?</font>>
        shape=plaintext
        style=""
    ];

    // Legend
    subgraph cluster_legend {
        label="";
        style=invis;
        margin=0;
        node [fontsize=9 width=1.2 height=0.35];
        leg_d [label="Design Analysis" fillcolor="#4A90D9" fontcolor="white"];
        leg_p [label="Implementation Plan" fillcolor="#7BC67E" fontcolor="white"];
        leg_s [label="Status Report" fillcolor="#BD10E0" fontcolor="white"];
        leg_d -> leg_p -> leg_s [style=invis];
    }

    title -> leg_d [style=invis];

    // ================================================================
    // MAIN FLOW
    // ================================================================

    mlp_design [
        label=<<b>MLP Design Analysis</b><br/><font point-size="9">March 10 · v0.8.15</font><br/><br/><font point-size="8">Analyzed ETIL matrix subsystem for MLP feasibility.<br/>Found <b>8 critical gaps</b> across 4 categories:</font><br/><br/><font point-size="8">• Element-wise ops (mat-hadamard, mat-add-col)<br/>• Activation functions (relu, sigmoid, tanh + derivatives)<br/>• Weight initialization (mat-randn, xavier, he)<br/>• Loss functions (MSE, softmax, cross-entropy)</font><br/><br/><font point-size="8">Recommended deferring in-place ops until MLP working.</font>>
        fillcolor="#4A90D9" fontcolor="white"
        width=4.5
    ];

    mlp_plan [
        label=<<b>MLP Primitives Plan</b><br/><font point-size="9">March 10 · v0.8.18 → v0.8.21</font><br/><br/><font point-size="8">Broke 17 new C++ primitives into 3 implementation stages:</font><br/><br/><font point-size="8"><b>Stage 1 — Forward Pass:</b> mat-relu, mat-sigmoid, mat-tanh,<br/>  mat-hadamard, mat-add-col, mat-randn (6 primitives)</font><br/><br/><font point-size="8"><b>Stage 2 — Backpropagation:</b> mat-relu', mat-sigmoid', mat-tanh',<br/>  mat-sum, mat-col-sum, mat-mean, mat-clip (7 primitives)</font><br/><br/><font point-size="8"><b>Stage 3 — Classification:</b> mat-softmax, mat-cross-entropy,<br/>  mat-apply, tanh scalar (4 primitives)</font>>
        fillcolor="#7BC67E" fontcolor="white"
        width=4.5
    ];

    mlp_status [
        label=<<b>MLP Status Report</b><br/><font point-size="9">March 18 · v1.0.0</font><br/><br/><font point-size="8">Assessed design document sections 2-6 against implementation:</font><br/><br/><font point-size="8" color="#90EE90">✓ All 17 C++ primitives implemented and tested</font><br/><font point-size="8" color="#90EE90">✓ mat-col-vec added (18th primitive, not in original plan)</font><br/><font point-size="8" color="#FFB3B3">✗ TIL-level MLP library: NOT DONE</font><br/><font point-size="8" color="#FFB3B3">✗ Selection engine: CRITICAL GAP</font><br/><font point-size="8" color="#FFB3B3">✗ Evolution engine: NOT STARTED</font><br/><br/><font point-size="8"><b>Verdict:</b> Primitives work. Need TIL library + engines.</font>>
        fillcolor="#BD10E0" fontcolor="white"
        width=4.5
    ];

    // Forward flow
    mlp_design -> mlp_plan [
        label="  design informs plan"
        color="#4A90D9"
        penwidth=2.5
    ];

    mlp_plan -> mlp_status [
        label="  8 days of implementation\n  then status check"
        color="#333333"
        penwidth=2.5
    ];

    // Backward reference
    mlp_status -> mlp_design [
        label="  references original\n  sections 2-6"
        color="#BD10E0"
        style=dashed
        penwidth=2
        constraint=false
    ];

    // What happened next
    next [
        label=<<font point-size="9" color="#333333"><b>→ Drives Iteration 3:</b> Status report's critical gaps<br/>lead directly to Layers 1-3 Plan (Mar 18)</font>>
        shape=plaintext
        style=""
    ];

    mlp_status -> next [style=dotted color="#999999" penwidth=1];
}
