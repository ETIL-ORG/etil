// Generated by CMake configure_file from src/core/version.cpp.in.
// Regenerated on every configure (project version + build timestamp).
// Sole TU that depends on those values, so a bump or a fresh
// timestamp triggers exactly one .cpp recompile instead of every
// consumer of <etil/core/version.hpp>.

#include "etil/core/version.hpp"

namespace etil::core {

const char* ETIL_VERSION = "@PROJECT_VERSION@";
const char* ETIL_BUILD_TIMESTAMP = "@ETIL_BUILD_TIMESTAMP@";

} // namespace etil::core
