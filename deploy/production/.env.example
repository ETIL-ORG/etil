# ETIL MCP Server — Production Environment Variables
#
# Copy this file to .env on the deploy target and set real values.
# The .env file is gitignored. Values here are placeholders only.
#
#   cp .env.example .env
#   openssl rand -hex 32             # generate a strong API key
#   chmod 600 .env
#   # Edit .env, fill in values below
#
# docker-compose.prod.yml references these via ${VAR:?} — compose
# will fail loudly if any required var is unset or empty.

# --- Runtime secrets ---
ETIL_MCP_API_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_KEY
ETIL_HTTP_ALLOWLIST=

# --- MongoDB connection ---
# Full mongodb:// or mongodb+srv:// URI. If using x.509 auth, the URI
# should reference the client cert mount points below.
ETIL_MONGODB_URI=mongodb://host.docker.internal:27017
ETIL_MONGODB_DATABASE=etil

# --- Container-internal paths (mount points) ---
# Where compose mounts the host directories INSIDE the container. These
# are conventions; change only if the container expects different paths.
ETIL_AUTH_CONFIG=/path/inside/container/for/auth/config
ETIL_SESSIONS_DIR=/path/inside/container/for/sessions
ETIL_LIBRARY_DIR=/path/inside/container/for/library
ETIL_MONGO_CLIENT_CERT_CONTAINER=/path/inside/container/for/mongo-client-cert
ETIL_MONGO_CA_CERT_CONTAINER=/path/inside/container/for/mongo-ca-cert

# --- Host-side paths (mount sources) ---
# Absolute paths on the deploy host that compose bind-mounts into the
# container. Keep these out of public documentation — they can reveal
# deployment layout.
ETIL_AUTH_HOST_DIR=/host/path/to/auth/config
ETIL_MONGO_CLIENT_CERT_HOST=/host/path/to/client-cert.pem
ETIL_MONGO_CA_CERT_HOST=/host/path/to/ca.pem

# --- Host-side numeric IDs (used by group_add in compose) ---
# GID of the user/group that owns the MongoDB certs on the host.
ETIL_CERT_GID=1006
ETIL_MONGO_GID=110
