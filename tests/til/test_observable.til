# test_observable.til — Observable integration tests
include tests/til/harness.til

# Helper
: expect-true true expect-eq ;

# --- Creation ---

." obs-from to-array: "
array-new 10 array-push 20 array-push 30 array-push obs-from obs-to-array
dup array-length 3 expect-eq
0 array-get 10 expect-eq

." obs-of: "
42 obs-of obs-to-array 0 array-get 42 expect-eq

." obs-empty: "
obs-empty obs-count 0 expect-eq

." obs-range: "
1 6 obs-range obs-to-array
dup array-length 5 expect-eq
dup 0 array-get 1 expect-eq
4 array-get 5 expect-eq

# --- Transform ---

: double dup + ;

." obs-map: "
1 4 obs-range ' double obs-map obs-to-array
dup 0 array-get 2 expect-eq
dup 1 array-get 4 expect-eq
2 array-get 6 expect-eq

: add-n + ;

." obs-map-with: "
1 4 obs-range ' add-n 100 obs-map-with obs-to-array
dup 0 array-get 101 expect-eq
dup 1 array-get 102 expect-eq
2 array-get 103 expect-eq

: even? 2 mod 0 = ;

." obs-filter: "
1 7 obs-range ' even? obs-filter obs-to-array
dup array-length 3 expect-eq
dup 0 array-get 2 expect-eq
dup 1 array-get 4 expect-eq
2 array-get 6 expect-eq

: lt? < ;

." obs-filter-with: "
1 10 obs-range ' lt? 5 obs-filter-with obs-count 4 expect-eq

# --- Accumulate ---

: add + ;

." obs-scan: "
1 4 obs-range ' add 0 obs-scan obs-to-array
dup 0 array-get 1 expect-eq
dup 1 array-get 3 expect-eq
2 array-get 6 expect-eq

." obs-reduce: "
1 6 obs-range ' add 0 obs-reduce 15 expect-eq

." obs-reduce empty: "
obs-empty ' add 0 obs-reduce 0 expect-eq

# --- Limiting ---

." obs-take: "
1 1000 obs-range 3 obs-take obs-to-array
dup array-length 3 expect-eq
dup 0 array-get 1 expect-eq
2 array-get 3 expect-eq

." obs-skip: "
1 6 obs-range 2 obs-skip obs-to-array
dup array-length 3 expect-eq
0 array-get 3 expect-eq

." obs-distinct: "
array-new 1 array-push 1 array-push 2 array-push 2 array-push 3 array-push
obs-from obs-distinct obs-to-array
dup array-length 3 expect-eq
dup 0 array-get 1 expect-eq
dup 1 array-get 2 expect-eq
2 array-get 3 expect-eq

# --- Combination ---

." obs-concat: "
1 3 obs-range 10 13 obs-range obs-concat obs-to-array
dup array-length 5 expect-eq
dup 0 array-get 1 expect-eq
dup 2 array-get 10 expect-eq
4 array-get 12 expect-eq

." obs-merge: "
1 3 obs-range 10 13 obs-range 0 obs-merge obs-count 5 expect-eq

." obs-zip: "
1 4 obs-range 10 13 obs-range obs-zip obs-to-array
dup array-length 3 expect-eq
drop
# check first pair
1 4 obs-range 10 13 obs-range obs-zip obs-to-array
0 array-get
dup 0 array-get 1 expect-eq
1 array-get 10 expect-eq

# --- Terminal ---

." obs-subscribe: "
variable sub-sum
0 sub-sum !
: sub-add sub-sum @ + sub-sum ! ;
1 4 obs-range ' sub-add obs-subscribe
sub-sum @ 6 expect-eq

." obs-to-array: "
1 3 obs-range obs-to-array array-length 2 expect-eq

." obs-count: "
1 11 obs-range obs-count 10 expect-eq

# --- Introspection ---

." obs?: "
obs-empty obs? expect-true

." obs? non-obs: "
42 obs? not expect-true

." obs-kind: "
1 5 obs-range obs-kind s" range" s= expect-true

# --- Pipeline composition ---

." map-filter-reduce pipeline: "
1 6 obs-range ' double obs-map ' even? obs-filter ' add 0 obs-reduce
# range 1..5, doubled: 2,4,6,8,10, all even, sum=30
30 expect-eq

." take-from-large-range: "
0 1000000 obs-range 5 obs-take obs-count 5 expect-eq

# =========================================================================
# Temporal Operators
# =========================================================================

# --- Timer ---

." obs-timer single-shot: "
0 0 obs-timer obs-to-array
dup array-length 1 expect-eq
0 array-get 0 expect-eq

." obs-timer repeating take 3: "
0 1 obs-timer 3 obs-take obs-to-array
dup array-length 3 expect-eq
dup 0 array-get 0 expect-eq
dup 1 array-get 1 expect-eq
2 array-get 2 expect-eq

." obs-timer kind: "
0 0 obs-timer obs-kind s" timer" s= expect-true

# --- Interval (self-hosted) ---

." obs-interval take 3: "
1 obs-interval 3 obs-take obs-to-array
dup array-length 3 expect-eq
dup 0 array-get 0 expect-eq
dup 1 array-get 1 expect-eq
2 array-get 2 expect-eq

# --- Delay ---

." obs-delay zero: "
42 obs-of 0 obs-delay obs-to-array
0 array-get 42 expect-eq

." obs-delay values: "
1 4 obs-range 1 obs-delay obs-to-array
dup array-length 3 expect-eq
0 array-get 1 expect-eq

# --- Timestamp ---

." obs-timestamp wraps: "
42 obs-of obs-timestamp obs-to-array
0 array-get
dup array-length 2 expect-eq
1 array-get 42 expect-eq

." obs-timestamp count: "
1 4 obs-range obs-timestamp obs-count 3 expect-eq

# --- TimeInterval ---

." obs-time-interval wraps: "
42 obs-of obs-time-interval obs-to-array
0 array-get
dup array-length 2 expect-eq
1 array-get 42 expect-eq

# --- Debounce ---

." obs-debounce-time last value: "
array-new 1 array-push 2 array-push 3 array-push obs-from 1000 obs-debounce-time obs-to-array
dup array-length 1 expect-eq
0 array-get 3 expect-eq

." obs-debounce-time empty: "
obs-empty 1000 obs-debounce-time obs-count 0 expect-eq

# --- Throttle ---

." obs-throttle-time zero window: "
1 6 obs-range 0 obs-throttle-time obs-count 5 expect-eq

." obs-throttle-time large window: "
1 6 obs-range 10000000 obs-throttle-time obs-to-array
dup array-length 1 expect-eq
0 array-get 1 expect-eq

# --- Timeout ---

." obs-timeout fast source: "
1 4 obs-range 10000000 obs-timeout obs-count 3 expect-eq

# --- BufferTime ---

." obs-buffer-time large window: "
1 4 obs-range 10000000 obs-buffer-time obs-to-array
dup array-length 1 expect-eq
0 array-get array-length 3 expect-eq

# --- TakeUntilTime ---

." obs-take-until-time large duration: "
1 4 obs-range 10000000 obs-take-until-time obs-count 3 expect-eq

# --- DelayEach ---

: zero-delay drop 0 ;

." obs-delay-each zero: "
1 4 obs-range ' zero-delay obs-delay-each obs-to-array
dup array-length 3 expect-eq
0 array-get 1 expect-eq

# --- AuditTime ---

." obs-audit-time: "
1 4 obs-range 0 obs-audit-time obs-count 0 > expect-true

# --- RetryDelay ---

." obs-retry-delay success: "
1 4 obs-range 0 3 obs-retry-delay obs-count 3 expect-eq

# --- Pipeline Composition with Temporal ---

." timer-take-timestamp pipeline: "
0 1 obs-timer 3 obs-take obs-timestamp obs-to-array
dup array-length 3 expect-eq
0 array-get 1 array-get 0 expect-eq

# ===================================================================
# AVO Phase 1: Buffer + Composition
# ===================================================================

# --- obs-buffer ---

." obs-buffer exact: "
1 7 obs-range 3 obs-buffer obs-to-array
dup array-length 2 expect-eq
0 array-get array-length 3 expect-eq

." obs-buffer trailing: "
1 8 obs-range 3 obs-buffer obs-to-array
dup array-length 3 expect-eq
2 array-get array-length 1 expect-eq

." obs-buffer single: "
1 4 obs-range 1 obs-buffer obs-to-array
array-length 3 expect-eq

." obs-buffer larger-than-source: "
1 4 obs-range 10 obs-buffer obs-to-array
dup array-length 1 expect-eq
0 array-get array-length 3 expect-eq

." obs-buffer empty: "
obs-empty 3 obs-buffer obs-to-array
array-length 0 expect-eq

# --- obs-buffer-when ---

: mod3? 3 mod 0= ;

." obs-buffer-when predicate: "
1 10 obs-range ' mod3? obs-buffer-when obs-to-array
dup array-length 3 expect-eq
0 array-get array-length 3 expect-eq

: always-true drop true ;
." obs-buffer-when always-true: "
1 4 obs-range ' always-true obs-buffer-when obs-to-array
array-length 3 expect-eq

# --- obs-window ---

." obs-window count: "
1 6 obs-range 3 obs-window obs-count 3 expect-eq

." obs-window first element: "
1 6 obs-range 3 obs-window obs-to-array
0 array-get 0 array-get 1 expect-eq

." obs-window slides: "
1 6 obs-range 3 obs-window obs-to-array
1 array-get 0 array-get 2 expect-eq

." obs-window too-short: "
1 3 obs-range 5 obs-window obs-to-array
array-length 0 expect-eq

." obs-window size-1: "
1 4 obs-range 1 obs-window obs-count 3 expect-eq

# --- obs-flat-map ---

: expand dup * obs-of ;

." obs-flat-map basic: "
1 4 obs-range ' expand obs-flat-map obs-to-array
dup array-length 3 expect-eq
dup 0 array-get 1 expect-eq
dup 1 array-get 4 expect-eq
2 array-get 9 expect-eq

: range-from 1 swap obs-range ;

." obs-flat-map multi-emission: "
3 6 obs-range ' range-from obs-flat-map obs-count 9 expect-eq

." obs-flat-map empty-sub: "
1 4 obs-range ' drop obs-empty obs-flat-map obs-count 0 expect-eq

# --- obs-to-string ---

." obs-to-string basic: "
array-new s" hello" array-push s" world" array-push obs-from
obs-to-string slength 10 expect-eq

." obs-to-string empty: "
obs-empty obs-to-string slength 0 expect-eq

# ===================================================================
# Gap Fill: High-Value RxJS Operators
# ===================================================================

# --- obs-tap ---

variable tap-count
: count-tap drop tap-count @ 1 + tap-count ! ;

." obs-tap passthrough: "
0 tap-count !
1 4 obs-range ' count-tap obs-tap obs-count 3 expect-eq

." obs-tap side-effect: "
tap-count @ 3 expect-eq

# --- obs-pairwise ---

." obs-pairwise count: "
1 5 obs-range obs-pairwise obs-count 3 expect-eq

." obs-pairwise first pair: "
1 5 obs-range obs-pairwise obs-to-array
0 array-get dup 0 array-get 1 expect-eq
1 array-get 2 expect-eq

." obs-pairwise single: "
1 2 obs-range obs-pairwise obs-count 0 expect-eq

# --- obs-first ---

." obs-first basic: "
1 10 obs-range obs-first obs-to-array
dup array-length 1 expect-eq
0 array-get 1 expect-eq

." obs-first empty: "
obs-empty obs-first obs-count 0 expect-eq

# --- obs-last ---

." obs-last basic: "
1 10 obs-range obs-last obs-to-array
dup array-length 1 expect-eq
0 array-get 9 expect-eq

." obs-last single: "
42 obs-of obs-last obs-to-array
0 array-get 42 expect-eq

# --- obs-take-while ---

: less5 5 < ;

." obs-take-while basic: "
1 10 obs-range ' less5 obs-take-while obs-to-array
array-length 4 expect-eq

." obs-take-while all pass: "
1 4 obs-range ' less5 obs-take-while obs-count 3 expect-eq

: never-true drop false ;

." obs-take-while none pass: "
1 10 obs-range ' never-true obs-take-while obs-count 0 expect-eq

# --- obs-distinct-until ---

." obs-distinct-until basic: "
array-new 1 array-push 1 array-push 2 array-push 2 array-push 1 array-push obs-from
obs-distinct-until obs-to-array
array-length 3 expect-eq

." obs-distinct-until all same: "
array-new 5 array-push 5 array-push 5 array-push obs-from
obs-distinct-until obs-count 1 expect-eq

." obs-distinct-until all different: "
1 5 obs-range obs-distinct-until obs-count 4 expect-eq

# --- obs-start-with ---

." obs-start-with basic: "
1 4 obs-range 0 obs-start-with obs-to-array
dup array-length 4 expect-eq
0 array-get 0 expect-eq

." obs-start-with empty source: "
obs-empty 42 obs-start-with obs-to-array
dup array-length 1 expect-eq
0 array-get 42 expect-eq

# --- obs-finalize ---

variable finalized
: set-finalized true finalized ! ;

." obs-finalize runs on success: "
false finalized !
1 4 obs-range ' set-finalized obs-finalize obs-count 3 expect-eq
finalized @ true expect-eq

# --- obs-switch-map ---

: to-obs obs-of ;

." obs-switch-map basic: "
1 4 obs-range ' to-obs obs-switch-map obs-to-array
dup array-length 1 expect-eq
0 array-get 3 expect-eq

: range-from 1 swap obs-range ;

." obs-switch-map last inner: "
3 6 obs-range ' range-from obs-switch-map obs-count 4 expect-eq

# --- obs-catch ---

: fallback 42 obs-of ;

." obs-catch no error: "
1 4 obs-range ' fallback obs-catch obs-count 3 expect-eq
