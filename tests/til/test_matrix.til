# test_matrix.til — TIL integration tests for matrix primitives
include tests/til/harness.til

# --- Constructors ---

." mat-new: " 3 4 mat-new dup mat-rows 3 expect-eq
." mat-new cols: " mat-cols 4 expect-eq

." mat-eye diag: " 3 mat-eye dup 0 0 mat-get 1.0 expect-eq
." mat-eye off-diag: " 0 1 mat-get 0.0 expect-eq

# --- Accessors ---

." mat-set/get: " 2 2 mat-new 0 1 3.14 mat-set 0 1 mat-get 3.14 expect-eq

." mat-row: " array-new array-new 1.0 array-push 2.0 array-push array-push array-new 3.0 array-push 4.0 array-push array-push array->mat 0 mat-row array-length 2 expect-eq

." mat-col: " array-new array-new 1.0 array-push 2.0 array-push array-push array-new 3.0 array-push 4.0 array-push array-push array->mat 1 mat-col array-length 2 expect-eq

# --- Arithmetic ---

." mat-eye mul: " 2 mat-eye 2 mat-eye mat* 0 0 mat-get 1.0 expect-eq

." mat+: " array-new array-new 1.0 array-push array-push array-new 2.0 array-push array-push array->mat array-new array-new 10.0 array-push array-push array-new 20.0 array-push array-push array->mat mat+ 0 0 mat-get 11.0 expect-eq

." mat-scale: " array-new array-new 2.0 array-push array-push array-new 4.0 array-push array-push array->mat 3.0 mat-scale 1 0 mat-get 12.0 expect-eq

." mat-transpose: " array-new array-new 1.0 array-push 2.0 array-push 3.0 array-push array-push array-new 4.0 array-push 5.0 array-push 6.0 array-push array-push array->mat mat-transpose dup mat-rows 3 expect-eq

# --- Solvers ---

." mat-solve flag: " array-new array-new 1.0 array-push 0.0 array-push array-push array-new 0.0 array-push 1.0 array-push array-push array->mat array-new array-new 5.0 array-push array-push array-new 3.0 array-push array-push array->mat mat-solve true expect-eq
." mat-solve val: " 0 0 mat-get 5.0 expect-eq

." mat-inv flag: " 2 mat-eye mat-inv true expect-eq
." mat-inv val: " 0 0 mat-get 1.0 expect-eq

." mat-det flag: " 2 mat-eye mat-det true expect-eq
." mat-det val: " 1.0 expect-eq

# --- Utilities ---

." mat-norm: " array-new array-new 3.0 array-push 4.0 array-push array-push array->mat mat-norm 5.0 expect-eq

." mat-trace: " array-new array-new 1.0 array-push 2.0 array-push array-push array-new 3.0 array-push 4.0 array-push array-push array->mat mat-trace 5.0 expect-eq

." mat-print: " 2 2 mat-new mat.

# --- Neural Network: Activation Functions ---

." mat-relu neg: " array-new array-new -3.0 array-push array-push array->mat mat-relu 0 0 mat-get 0.0 expect-eq
." mat-relu pos: " array-new array-new 5.0 array-push array-push array->mat mat-relu 0 0 mat-get 5.0 expect-eq

." mat-sigmoid(0): " array-new array-new 0.0 array-push array-push array->mat mat-sigmoid 0 0 mat-get 0.5 expect-eq

." mat-tanh(0): " array-new array-new 0.0 array-push array-push array->mat mat-tanh 0 0 mat-get 0.0 expect-eq

." mat-hadamard: " array-new array-new 2.0 array-push 3.0 array-push array-push array->mat array-new array-new 4.0 array-push 5.0 array-push array-push array->mat mat-hadamard 0 0 mat-get 8.0 expect-eq

." mat-add-col: " array-new array-new 1.0 array-push 2.0 array-push array-push array-new 3.0 array-push 4.0 array-push array-push array->mat array-new array-new 10.0 array-push array-push array-new 20.0 array-push array-push array->mat mat-add-col 0 0 mat-get 11.0 expect-eq

." mat-randn: " 42 random-seed 3 3 mat-randn mat-rows 3 expect-eq

# --- Neural Network: Backpropagation ---

." mat-relu' neg: " array-new array-new -1.0 array-push array-push array->mat mat-relu' 0 0 mat-get 0.0 expect-eq
." mat-relu' pos: " array-new array-new 2.0 array-push array-push array->mat mat-relu' 0 0 mat-get 1.0 expect-eq

." mat-sum: " array-new array-new 1.0 array-push 2.0 array-push array-push array-new 3.0 array-push 4.0 array-push array-push array->mat mat-sum 10.0 expect-eq

." mat-col-sum: " array-new array-new 1.0 array-push 2.0 array-push array-push array-new 3.0 array-push 4.0 array-push array-push array->mat mat-col-sum 0 0 mat-get 3.0 expect-eq

." mat-mean: " array-new array-new 2.0 array-push 4.0 array-push array-push array-new 6.0 array-push 8.0 array-push array-push array->mat mat-mean 5.0 expect-eq

." mat-clip lo: " array-new array-new -5.0 array-push 0.5 array-push 10.0 array-push array-push array->mat 0.0 1.0 mat-clip dup 0 0 mat-get 0.0 expect-eq
." mat-clip hi: " 0 2 mat-get 1.0 expect-eq

." tanh scalar: " 0.0 tanh 0.0 expect-eq

# --- Neural Network: Classification ---

: test-softmax-sum
    array-new array-new 1.0 array-push array-push array-new 2.0 array-push array-push array-new 3.0 array-push array-push array->mat
    mat-softmax mat-sum 1.0 - abs 0.0001 <
    if pass else fail then
;
." mat-softmax: " test-softmax-sum

: triple 3.0 * ;
." mat-apply: " array-new array-new 1.0 array-push 2.0 array-push 3.0 array-push array-push array->mat ' triple mat-apply 0 1 mat-get 6.0 expect-eq
