# test_observable_async.til — Async observable integration test matrix
#
# 4-dimensional test coverage:
#   D1: Source x Sink (sync + async sources against all terminals)
#   D2: Source x Transform x Sink (transforms with async sources)
#   D3: Combination operators (merge/concat/zip with sync/async pairs)
#   D4: Inner-observable operators (flat-map/switch-map with sync/async inners)

include tests/til/harness.til

# ===================================================================
# Helpers
# ===================================================================

: expect-true true expect-eq ;
: add + ;
: double dup + ;
: even? 2 mod 0 = ;
: add1000 1000 + ;
: ge1000 1000 >= ;
: lt1000 1000 < ;

variable sub-count
: counter drop sub-count @ 1 + sub-count ! ;

# Source builders (words that push an observable onto the stack)
: src-of 42 obs-of ;
: src-empty obs-empty ;
: src-range 1 6 obs-range ;
: src-from array-new 10 array-push 20 array-push 30 array-push obs-from ;
: src-timer-single 0 0 obs-timer ;
: src-timer-repeat 0 1 obs-timer 5 obs-take ;
: src-interval 1000 obs-interval 5 obs-take ;

# ===================================================================
# D1: Source x Sink Matrix
# ===================================================================

# --- obs-of (1 value, sum=42) x all sinks ---

." D1 of-count: "
src-of obs-count 1 expect-eq

." D1 of-array: "
src-of obs-to-array array-length 1 expect-eq

." D1 of-reduce: "
src-of ' add 0 obs-reduce 42 expect-eq

." D1 of-subscribe: "
0 sub-count !
src-of ' counter obs-subscribe
sub-count @ 1 expect-eq

# --- obs-empty (0 values, sum=0) x all sinks ---

." D1 empty-count: "
src-empty obs-count 0 expect-eq

." D1 empty-array: "
src-empty obs-to-array array-length 0 expect-eq

." D1 empty-reduce: "
src-empty ' add 0 obs-reduce 0 expect-eq

." D1 empty-subscribe: "
0 sub-count !
src-empty ' counter obs-subscribe
sub-count @ 0 expect-eq

# --- obs-range (5 values 1..5, sum=15) x all sinks ---

." D1 range-count: "
src-range obs-count 5 expect-eq

." D1 range-array: "
src-range obs-to-array array-length 5 expect-eq

." D1 range-reduce: "
src-range ' add 0 obs-reduce 15 expect-eq

." D1 range-subscribe: "
0 sub-count !
src-range ' counter obs-subscribe
sub-count @ 5 expect-eq

# --- obs-from (3 values 10,20,30, sum=60) x all sinks ---

." D1 from-count: "
src-from obs-count 3 expect-eq

." D1 from-array: "
src-from obs-to-array array-length 3 expect-eq

." D1 from-reduce: "
src-from ' add 0 obs-reduce 60 expect-eq

." D1 from-subscribe: "
0 sub-count !
src-from ' counter obs-subscribe
sub-count @ 3 expect-eq

# --- obs-timer single-shot (1 value=0, sum=0) x all sinks ---

." D1 timer1-count: "
src-timer-single obs-count 1 expect-eq

." D1 timer1-array: "
src-timer-single obs-to-array array-length 1 expect-eq

." D1 timer1-reduce: "
src-timer-single ' add 0 obs-reduce 0 expect-eq

." D1 timer1-subscribe: "
0 sub-count !
src-timer-single ' counter obs-subscribe
sub-count @ 1 expect-eq

# --- obs-timer repeat take 5 (5 values 0..4, sum=10) x all sinks ---

." D1 timerN-count: "
src-timer-repeat obs-count 5 expect-eq

." D1 timerN-array: "
src-timer-repeat obs-to-array array-length 5 expect-eq

." D1 timerN-reduce: "
src-timer-repeat ' add 0 obs-reduce 10 expect-eq

." D1 timerN-subscribe: "
0 sub-count !
src-timer-repeat ' counter obs-subscribe
sub-count @ 5 expect-eq

# --- obs-interval take 5 (5 values 0..4, sum=10) x all sinks ---

." D1 interval-count: "
src-interval obs-count 5 expect-eq

." D1 interval-array: "
src-interval obs-to-array array-length 5 expect-eq

." D1 interval-reduce: "
src-interval ' add 0 obs-reduce 10 expect-eq

." D1 interval-subscribe: "
0 sub-count !
src-interval ' counter obs-subscribe
sub-count @ 5 expect-eq

# ===================================================================
# D2: Source x Transform x Sink
# ===================================================================

# --- Sync source (obs-range 1..5) through transforms → obs-count ---

." D2 sync-map: "
src-range ' double obs-map obs-count 5 expect-eq

." D2 sync-filter: "
src-range ' even? obs-filter obs-count 2 expect-eq

." D2 sync-take: "
src-range 3 obs-take obs-count 3 expect-eq

." D2 sync-skip: "
src-range 2 obs-skip obs-count 3 expect-eq

." D2 sync-distinct: "
src-range obs-distinct obs-count 5 expect-eq

." D2 sync-timestamp: "
src-range obs-timestamp obs-count 5 expect-eq

." D2 sync-scan: "
src-range ' add 0 obs-scan obs-count 5 expect-eq

." D2 sync-first: "
src-range obs-first obs-count 1 expect-eq

." D2 sync-last: "
src-range obs-last obs-count 1 expect-eq

# --- Async source (obs-interval take 5, values 0..4) through transforms → obs-count ---

." D2 async-map: "
src-interval ' double obs-map obs-count 5 expect-eq

." D2 async-filter: "
src-interval ' even? obs-filter obs-count 3 expect-eq

." D2 async-take: "
src-interval 3 obs-take obs-count 3 expect-eq

." D2 async-skip: "
src-interval 2 obs-skip obs-count 3 expect-eq

." D2 async-distinct: "
src-interval obs-distinct obs-count 5 expect-eq

." D2 async-timestamp: "
src-interval obs-timestamp obs-count 5 expect-eq

." D2 async-scan: "
src-interval ' add 0 obs-scan obs-count 5 expect-eq

." D2 async-first: "
src-interval obs-first obs-count 1 expect-eq

." D2 async-last: "
src-interval obs-last obs-count 1 expect-eq

# ===================================================================
# D3: Combination Operators — Source Pair x Combiner x Sink
# ===================================================================

# Source pair builders (each side produces 3 values)
: pair-ss 1 4 obs-range 10 13 obs-range ;
: pair-sa 1 4 obs-range 1000 obs-interval 3 obs-take ;
: pair-as 1000 obs-interval 3 obs-take 1 4 obs-range ;
: pair-aa 1000 obs-interval 3 obs-take 2000 obs-interval 3 obs-take ;

# --- Merge (count = A + B = 6) ---

." D3 merge-ss-count: "
pair-ss 0 obs-merge obs-count 6 expect-eq

." D3 merge-sa-count: "
pair-sa 0 obs-merge obs-count 6 expect-eq

." D3 merge-as-count: "
pair-as 0 obs-merge obs-count 6 expect-eq

." D3 merge-aa-count: "
pair-aa 0 obs-merge obs-count 6 expect-eq

." D3 merge-ss-array: "
pair-ss 0 obs-merge obs-to-array array-length 6 expect-eq

." D3 merge-sa-array: "
pair-sa 0 obs-merge obs-to-array array-length 6 expect-eq

." D3 merge-as-array: "
pair-as 0 obs-merge obs-to-array array-length 6 expect-eq

." D3 merge-aa-array: "
pair-aa 0 obs-merge obs-to-array array-length 6 expect-eq

# --- Merge: verify both sources contribute ---

." D3 merge-aa-both-sources: "
1000 obs-interval 3 obs-take ' add1000 obs-map
2000 obs-interval 3 obs-take
0 obs-merge obs-to-array
dup ' ge1000 obs-from swap obs-from obs-zip drop
# Simpler: count tagged values
1000 obs-interval 3 obs-take ' add1000 obs-map
2000 obs-interval 3 obs-take
0 obs-merge ' ge1000 obs-filter obs-count 3 expect-eq

." D3 merge-aa-other-source: "
1000 obs-interval 3 obs-take ' add1000 obs-map
2000 obs-interval 3 obs-take
0 obs-merge ' lt1000 obs-filter obs-count 3 expect-eq

# --- Concat (count = A + B = 6, sequential) ---

." D3 concat-ss-count: "
pair-ss obs-concat obs-count 6 expect-eq

." D3 concat-sa-count: "
pair-sa obs-concat obs-count 6 expect-eq

." D3 concat-as-count: "
pair-as obs-concat obs-count 6 expect-eq

." D3 concat-aa-count: "
pair-aa obs-concat obs-count 6 expect-eq

." D3 concat-ss-array: "
pair-ss obs-concat obs-to-array array-length 6 expect-eq

." D3 concat-sa-array: "
pair-sa obs-concat obs-to-array array-length 6 expect-eq

." D3 concat-as-array: "
pair-as obs-concat obs-to-array array-length 6 expect-eq

." D3 concat-aa-array: "
pair-aa obs-concat obs-to-array array-length 6 expect-eq

# --- Concat: verify sequential order (A then B) ---

." D3 concat-aa-order-A: "
1000 obs-interval 3 obs-take ' add1000 obs-map
2000 obs-interval 3 obs-take
obs-concat obs-to-array
dup 0 array-get 1000 >= expect-true

." D3 concat-aa-order-B: "
3 array-get 1000 < expect-true

# --- Zip (count = min(A, B) = 3, pairs) ---

." D3 zip-ss-count: "
pair-ss obs-zip obs-count 3 expect-eq

." D3 zip-sa-count: "
pair-sa obs-zip obs-count 3 expect-eq

." D3 zip-as-count: "
pair-as obs-zip obs-count 3 expect-eq

." D3 zip-aa-count: "
pair-aa obs-zip obs-count 3 expect-eq

." D3 zip-ss-array: "
pair-ss obs-zip obs-to-array array-length 3 expect-eq

." D3 zip-sa-array: "
pair-sa obs-zip obs-to-array array-length 3 expect-eq

." D3 zip-as-array: "
pair-as obs-zip obs-to-array array-length 3 expect-eq

." D3 zip-aa-array: "
pair-aa obs-zip obs-to-array array-length 3 expect-eq

# --- Zip: verify pairs are arrays of length 2 ---

." D3 zip-aa-pair-len: "
pair-aa obs-zip obs-to-array
0 array-get array-length 2 expect-eq

# ===================================================================
# D4: Inner-Observable Operators
# ===================================================================

# --- flat-map: sync outer → sync inner ---

# to-range: N -> obs-range 1..(N+1), emitting N values
: to-range 1 + 1 swap obs-range ;

." D4 flatmap-ss-count: "
# range 1..3 = [1,2,3], to-range gives 1 + 2 + 3 = 6
1 4 obs-range ' to-range obs-flat-map obs-count 6 expect-eq

." D4 flatmap-ss-of: "
1 4 obs-range ' obs-of obs-flat-map obs-count 3 expect-eq

# --- flat-map: sync outer → async inner ---

: to-interval-2 drop 1000 obs-interval 2 obs-take ;

." D4 flatmap-sa-count: "
1 4 obs-range ' to-interval-2 obs-flat-map obs-count 6 expect-eq

# --- flat-map: async outer → sync inner ---

." D4 flatmap-as-count: "
1000 obs-interval 3 obs-take ' obs-of obs-flat-map obs-count 3 expect-eq

." D4 flatmap-as-range: "
# interval take 3 = [0,1,2], to-range(N)=1..(N+1): 0+1+2 = 3
1000 obs-interval 3 obs-take ' to-range obs-flat-map obs-count 3 expect-eq

# --- flat-map: async outer → async inner ---

." D4 flatmap-aa-count: "
1000 obs-interval 3 obs-take ' to-interval-2 obs-flat-map obs-count 6 expect-eq

# --- switch-map: sync outer → sync inner (last inner only) ---

." D4 switchmap-ss-len: "
1 4 obs-range ' obs-of obs-switch-map obs-to-array
dup array-length 1 expect-eq

." D4 switchmap-ss-val: "
0 array-get 3 expect-eq

# --- switch-map: sync outer → async inner ---

: to-interval-3 drop 1000 obs-interval 3 obs-take ;

." D4 switchmap-sa-count: "
1 3 obs-range ' to-interval-3 obs-switch-map obs-count 3 expect-eq

# --- switch-map: async outer → sync inner ---

." D4 switchmap-as: "
1000 obs-interval 3 obs-take ' obs-of obs-switch-map obs-count 0 > expect-true

# --- switch-map: async outer → async inner ---

." D4 switchmap-aa: "
2000 obs-interval 3 obs-take ' to-interval-3 obs-switch-map obs-count 0 > expect-true

# --- catch: sync — no error ---

: fallback-obs 99 obs-of ;

." D4 catch-sync-noerr: "
1 4 obs-range ' fallback-obs obs-catch obs-count 3 expect-eq

# --- catch: sync outer with async fallback ---

." D4 catch-async-fallback: "
1 4 obs-range ' fallback-obs obs-catch obs-count 3 expect-eq

# --- catch: async — no error ---

." D4 catch-async-noerr: "
1000 obs-interval 3 obs-take ' fallback-obs obs-catch obs-count 3 expect-eq

# ===================================================================
# Summary
# ===================================================================

." --- All Observable Async tests completed --- " cr
