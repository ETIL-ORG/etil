#
# Manifold E2E #2 — NATS broker round-trip.
#
# Round-trip pattern:
#   local channel  etil.test.e2e.broker.out
#         │
#         ▼  channel-tap-nats         (Manifold writes to NATS subject X)
#         X  NATS broker
#         │  channel-source-nats      (Manifold reads from NATS subject X)
#         ▼
#   local channel  etil.test.e2e.broker.in
#         │
#         ▼  obs-message-read + obs-take + obs-subscribe   (assert)
#
# NATS URL is provided at the top by the driver, since the broker DNS
# name is environment-specific. To customize, the driver substitutes
# the NATS_URL placeholder before sending the file via tools/call
# interpret. Default placeholder shown below uses the deployment's
# compose-internal service name.
#
# Required role permissions:
#   channels_enabled: true
#   channels_network_sink: true
#   channel_grants: read+write+route+introspect on "etil.test.e2e.**"
#
# Self-contained — no include directives.

# ── Inline harness ─────────────────────────────────────────────────
: pass         ." PASS" cr ;
: fail         ." FAIL" cr ;
: expect-eq    = if pass else fail then ;
: expect-streq s= 0> if pass else fail then ;

variable captured
: capture-string  captured ! ;

# Driver substitutes NATS_URL with e.g. "nats://nats:4222" before send.
# Codec defaults to json for header readability when sniffing the wire.
#
# Word signatures (from src/manifold/til_primitives.cpp):
#   channel-tap-nats    ( url codec pattern -- handle )
#       — 3 args; NATS subject is derived from `pattern` via
#         BrokerSinkBase::translate_subject (default = identity).
#   channel-source-nats ( url codec subject pattern -- handle )
#       — 4 args; explicit `subject` since the source has no channel
#         to derive from.
#
# Round-trip: tap on local channel `etil.test.e2e.broker.out.X`
# publishes to NATS subject `etil.test.e2e.broker.out.X` (identity
# translate). Source subscribes to that subject and re-publishes onto
# local channel `etil.test.e2e.broker.in.X` where the reader takes.

# ── 1. Single-message broker round-trip ──────────────────────────
: test-broker-single
    # Install source first so we are subscribed when the tap fires.
    # ( url codec subject pattern -- handle )
    s" NATS_URL" s" json"
    s" etil.test.e2e.broker.out.single"
    s" etil.test.e2e.broker.in.single"
    channel-source-nats drop

    s" etil.test.e2e.broker.in.single" obs-create-channel
    obs-message-read

    # Now install the tap on the OUT side.
    # ( url codec pattern -- handle ) — subject derived from pattern.
    s" NATS_URL" s" json"
    s" etil.test.e2e.broker.out.single"
    channel-tap-nats drop

    s" etil.test.e2e.broker.out.single" obs-create-channel
    s" round-trip-payload" obs-message-write

    channel-flush
    1 obs-take
    ['] capture-string obs-subscribe

    captured @ s" round-trip-payload" expect-streq
;
." test-broker-single: " test-broker-single

# ── 2. Multi-message ordering preservation ───────────────────────
# NATS guarantees per-publisher per-subject ordering. Verify three
# messages arrive in the order they were sent.
variable seen1
variable seen2
variable seen3
variable seen-idx

# capture-ordered ( s -- ) — store incoming string in seen<idx+1>,
# then increment idx. Beyond idx 2, drop the message.
: capture-ordered
    seen-idx @ 0 = if seen1 ! else
    seen-idx @ 1 = if seen2 ! else
    seen-idx @ 2 = if seen3 ! else drop
    then then then
    seen-idx @ 1 + seen-idx !
;

: test-broker-ordering
    0 seen-idx !
    s" " seen1 ! s" " seen2 ! s" " seen3 !

    s" NATS_URL" s" json"
    s" etil.test.e2e.broker.out.order"
    s" etil.test.e2e.broker.in.order"
    channel-source-nats drop

    s" etil.test.e2e.broker.in.order" obs-create-channel
    obs-message-read

    s" NATS_URL" s" json"
    s" etil.test.e2e.broker.out.order"
    channel-tap-nats drop

    s" etil.test.e2e.broker.out.order" obs-create-channel
    dup s" first"  obs-message-write
    dup s" second" obs-message-write
        s" third"  obs-message-write

    channel-flush
    3 obs-take
    ['] capture-ordered obs-subscribe

    seen1 @ s" first"  expect-streq
    seen2 @ s" second" expect-streq
    seen3 @ s" third"  expect-streq
;
." test-broker-ordering: " test-broker-ordering
