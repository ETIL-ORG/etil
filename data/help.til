# help.til -- Built-in help metadata for all ETIL words
# Loaded on startup after builtins.til.
# Uses stack-based meta! to attach description, stack-effect, and category to each word.
# Syntax: s" word" s" key" s" fmt" s" content" meta! drop
# NOTE: No # character inside "..." strings -- it starts a comment and eats the closing quote.
# Use \n=> to show expected output on a separate line in examples.
# Use s| content| instead of s" content" when content contains double-quote characters.

# --- Arithmetic ---

s" +" s" description" s" text" s" Add two numbers" meta! drop
s" +" s" stack-effect" s" text" s" ( a b -- a+b )" meta! drop
s" +" s" category" s" text" s" arithmetic" meta! drop

s" -" s" description" s" text" s" Subtract top from second" meta! drop
s" -" s" stack-effect" s" text" s" ( a b -- a-b )" meta! drop
s" -" s" category" s" text" s" arithmetic" meta! drop

s" *" s" description" s" text" s" Multiply two numbers" meta! drop
s" *" s" stack-effect" s" text" s" ( a b -- a*b )" meta! drop
s" *" s" category" s" text" s" arithmetic" meta! drop

s" /" s" description" s" text" s" Divide second by top (truncating for integers)" meta! drop
s" /" s" stack-effect" s" text" s" ( a b -- a/b )" meta! drop
s" /" s" category" s" text" s" arithmetic" meta! drop

s" mod" s" description" s" text" s" Remainder of second divided by top" meta! drop
s" mod" s" stack-effect" s" text" s" ( a b -- a%b )" meta! drop
s" mod" s" category" s" text" s" arithmetic" meta! drop

s" /mod" s" description" s" text" s" Divide with remainder" meta! drop
s" /mod" s" stack-effect" s" text" s" ( a b -- rem quot )" meta! drop
s" /mod" s" category" s" text" s" arithmetic" meta! drop

s" negate" s" description" s" text" s" Negate top of stack" meta! drop
s" negate" s" stack-effect" s" text" s" ( n -- -n )" meta! drop
s" negate" s" category" s" text" s" arithmetic" meta! drop

s" abs" s" description" s" text" s" Absolute value of top of stack" meta! drop
s" abs" s" stack-effect" s" text" s" ( n -- |n| )" meta! drop
s" abs" s" category" s" text" s" arithmetic" meta! drop

s" +" s" examples" s" code" s" 3 4 + .\n=> 7" meta! drop
s" -" s" examples" s" code" s" 10 3 - .\n=> 7" meta! drop
s" *" s" examples" s" code" s" 6 7 * .\n=> 42" meta! drop
s" /" s" examples" s" code" s" 42 6 / .\n=> 7" meta! drop
s" mod" s" examples" s" code" s" 10 3 mod .\n=> 1" meta! drop
s" /mod" s" examples" s" code" s" 10 3 /mod .| quot=| . .| rem=| .\n=> quot=3 rem=1 " meta! drop
s" negate" s" examples" s" code" s" 5 negate .\n=> -5" meta! drop
s" abs" s" examples" s" code" s" -7 abs .\n=> 7" meta! drop

s" max" s" description" s" text" s" Return the greater of two values" meta! drop
s" max" s" stack-effect" s" text" s" ( n1 n2 -- max )" meta! drop
s" max" s" category" s" text" s" arithmetic" meta! drop
s" max" s" examples" s" code" s" 3 7 max .\n=> 7" meta! drop

s" min" s" description" s" text" s" Return the lesser of two values" meta! drop
s" min" s" stack-effect" s" text" s" ( n1 n2 -- min )" meta! drop
s" min" s" category" s" text" s" arithmetic" meta! drop
s" min" s" examples" s" code" s" 3 7 min .\n=> 3" meta! drop

s" 1+" s" description" s" text" s" Increment by one" meta! drop
s" 1+" s" stack-effect" s" text" s" ( n -- n+1 )" meta! drop
s" 1+" s" category" s" text" s" arithmetic" meta! drop
s" 1+" s" examples" s" code" s" 5 1+ .\n=> 6" meta! drop

s" 1-" s" description" s" text" s" Decrement by one" meta! drop
s" 1-" s" stack-effect" s" text" s" ( n -- n-1 )" meta! drop
s" 1-" s" category" s" text" s" arithmetic" meta! drop
s" 1-" s" examples" s" code" s" 5 1- .\n=> 4" meta! drop

# --- Stack ---

s" dup" s" description" s" text" s" Duplicate top of stack" meta! drop
s" dup" s" stack-effect" s" text" s" ( x -- x x )" meta! drop
s" dup" s" category" s" text" s" stack" meta! drop

s" drop" s" description" s" text" s" Remove top of stack" meta! drop
s" drop" s" stack-effect" s" text" s" ( x -- )" meta! drop
s" drop" s" category" s" text" s" stack" meta! drop

s" swap" s" description" s" text" s" Swap top two stack items" meta! drop
s" swap" s" stack-effect" s" text" s" ( a b -- b a )" meta! drop
s" swap" s" category" s" text" s" stack" meta! drop

s" over" s" description" s" text" s" Copy second item to top" meta! drop
s" over" s" stack-effect" s" text" s" ( a b -- a b a )" meta! drop
s" over" s" category" s" text" s" stack" meta! drop

s" rot" s" description" s" text" s" Rotate third item to top" meta! drop
s" rot" s" stack-effect" s" text" s" ( a b c -- b c a )" meta! drop
s" rot" s" category" s" text" s" stack" meta! drop

s" dup" s" examples" s" code" s" 5 dup . .\n=> 5 5" meta! drop
s" drop" s" examples" s" code" s" 1 2 drop .\n=> 1" meta! drop
s" swap" s" examples" s" code" s" 1 2 swap . .\n=> 1 2" meta! drop
s" over" s" examples" s" code" s" 1 2 over . . .\n=> 1 2 1" meta! drop
s" rot" s" examples" s" code" s" 1 2 3 rot . . .\n=> 1 3 2" meta! drop

s" pick" s" description" s" text" s" Copy the Nth item (zero-based) below TOS onto TOS" meta! drop
s" pick" s" stack-effect" s" text" s" ( xn ... x1 x0 n -- xn ... x1 x0 xn )" meta! drop
s" pick" s" category" s" text" s" stack" meta! drop
s" pick" s" examples" s" code" s| 10 20 30 0 pick . cr drop drop drop\n=> 30 | meta! drop

s" nip" s" description" s" text" s" Remove second item, keeping TOS" meta! drop
s" nip" s" stack-effect" s" text" s" ( x1 x2 -- x2 )" meta! drop
s" nip" s" category" s" text" s" stack" meta! drop
s" nip" s" examples" s" code" s" 1 2 nip .\n=> 2" meta! drop

s" tuck" s" description" s" text" s" Copy TOS under second item" meta! drop
s" tuck" s" stack-effect" s" text" s" ( x1 x2 -- x2 x1 x2 )" meta! drop
s" tuck" s" category" s" text" s" stack" meta! drop
s" tuck" s" examples" s" code" s" 1 2 tuck . . .\n=> 2 1 2" meta! drop

s" depth" s" description" s" text" s" Push current data stack depth" meta! drop
s" depth" s" stack-effect" s" text" s" ( -- u )" meta! drop
s" depth" s" category" s" text" s" stack" meta! drop
s" depth" s" examples" s" code" s" 10 20 30 depth .\n=> 3" meta! drop

s" ?dup" s" description" s" text" s" Duplicate TOS if non-zero" meta! drop
s" ?dup" s" stack-effect" s" text" s" ( x -- x x | 0 )" meta! drop
s" ?dup" s" category" s" text" s" stack" meta! drop
s" ?dup" s" examples" s" code" s" 5 ?dup . .\n=> 5 5" meta! drop

s" roll" s" description" s" text" s" Move the Nth item (zero-based) to TOS, removing it from its original position" meta! drop
s" roll" s" stack-effect" s" text" s" ( xu ... x0 u -- xu-1 ... x0 xu )" meta! drop
s" roll" s" category" s" text" s" stack" meta! drop
s" roll" s" examples" s" code" s" 10 20 30 2 roll . . .\n=> 10 30 20" meta! drop

s" -rot" s" description" s" text" s" Reverse rotate: move TOS under third item" meta! drop
s" -rot" s" stack-effect" s" text" s" ( a b c -- c a b )" meta! drop
s" -rot" s" category" s" text" s" stack" meta! drop
s" -rot" s" examples" s" code" s" 1 2 3 -rot . . .\n=> 2 3 1" meta! drop

# --- Comparison ---

s" =" s" description" s" text" s" Test equality" meta! drop
s" =" s" stack-effect" s" text" s" ( a b -- bool )" meta! drop
s" =" s" category" s" text" s" comparison" meta! drop

s" <>" s" description" s" text" s" Test inequality" meta! drop
s" <>" s" stack-effect" s" text" s" ( a b -- bool )" meta! drop
s" <>" s" category" s" text" s" comparison" meta! drop

s" <" s" description" s" text" s" Test less than" meta! drop
s" <" s" stack-effect" s" text" s" ( a b -- bool )" meta! drop
s" <" s" category" s" text" s" comparison" meta! drop

s" >" s" description" s" text" s" Test greater than" meta! drop
s" >" s" stack-effect" s" text" s" ( a b -- bool )" meta! drop
s" >" s" category" s" text" s" comparison" meta! drop

s" <=" s" description" s" text" s" Test less than or equal" meta! drop
s" <=" s" stack-effect" s" text" s" ( a b -- bool )" meta! drop
s" <=" s" category" s" text" s" comparison" meta! drop

s" >=" s" description" s" text" s" Test greater than or equal" meta! drop
s" >=" s" stack-effect" s" text" s" ( a b -- bool )" meta! drop
s" >=" s" category" s" text" s" comparison" meta! drop

s" 0=" s" description" s" text" s" Test if zero" meta! drop
s" 0=" s" stack-effect" s" text" s" ( n -- bool )" meta! drop
s" 0=" s" category" s" text" s" comparison" meta! drop

s" 0<" s" description" s" text" s" Test if negative" meta! drop
s" 0<" s" stack-effect" s" text" s" ( n -- bool )" meta! drop
s" 0<" s" category" s" text" s" comparison" meta! drop

s" 0>" s" description" s" text" s" Test if positive" meta! drop
s" 0>" s" stack-effect" s" text" s" ( n -- bool )" meta! drop
s" 0>" s" category" s" text" s" comparison" meta! drop

s" =" s" examples" s" code" s" 3 3 = .| equal? | .\n=> equal? -1 " meta! drop
s" <>" s" examples" s" code" s" 3 4 <> .| not-equal? | .\n=> not-equal? -1 " meta! drop
s" <" s" examples" s" code" s" 3 4 < .| less? | .\n=> less? -1 " meta! drop
s" >" s" examples" s" code" s" 4 3 > .| greater? | .\n=> greater? -1 " meta! drop
s" <=" s" examples" s" code" s" 3 3 <= .| lte? | .\n=> lte? -1 " meta! drop
s" >=" s" examples" s" code" s" 3 3 >= .| gte? | .\n=> gte? -1 " meta! drop
s" 0=" s" examples" s" code" s" 0 0= .| zero? | .\n=> zero? -1 " meta! drop
s" 0<" s" examples" s" code" s" -1 0< .| negative? | .\n=> negative? -1 " meta! drop
s" 0>" s" examples" s" code" s" 1 0> .| positive? | .\n=> positive? -1 " meta! drop

# --- Logic ---

s" and" s" description" s" text" s" Both Boolean: logical AND (returns bool). Both Integer: bitwise AND (returns int). Mixed types: error." meta! drop
s" and" s" stack-effect" s" text" s" ( a b -- a&b )" meta! drop
s" and" s" category" s" text" s" logic" meta! drop

s" or" s" description" s" text" s" Both Boolean: logical OR (returns bool). Both Integer: bitwise OR (returns int). Mixed types: error." meta! drop
s" or" s" stack-effect" s" text" s" ( a b -- a|b )" meta! drop
s" or" s" category" s" text" s" logic" meta! drop

s" xor" s" description" s" text" s" Both Boolean: logical XOR (returns bool). Both Integer: bitwise XOR (returns int). Mixed types: error." meta! drop
s" xor" s" stack-effect" s" text" s" ( a b -- a^b )" meta! drop
s" xor" s" category" s" text" s" logic" meta! drop

s" invert" s" description" s" text" s" Boolean: logical NOT (returns bool). Integer: bitwise NOT (returns int)." meta! drop
s" invert" s" stack-effect" s" text" s" ( n -- ~n )" meta! drop
s" invert" s" category" s" text" s" logic" meta! drop

s" and" s" examples" s" code" s" -1 -1 and .\n=> -1" meta! drop
s" or" s" examples" s" code" s" 0 -1 or .\n=> -1" meta! drop
s" xor" s" examples" s" code" s" -1 -1 xor .\n=> 0" meta! drop
s" invert" s" examples" s" code" s" 0 invert .\n=> -1" meta! drop

s" lshift" s" description" s" text" s" Left bit shift" meta! drop
s" lshift" s" stack-effect" s" text" s" ( x u -- x<<u )" meta! drop
s" lshift" s" category" s" text" s" logic" meta! drop
s" lshift" s" examples" s" code" s" 1 8 lshift .\n=> 256" meta! drop

s" rshift" s" description" s" text" s" Logical right bit shift" meta! drop
s" rshift" s" stack-effect" s" text" s" ( x u -- x>>u )" meta! drop
s" rshift" s" category" s" text" s" logic" meta! drop
s" rshift" s" examples" s" code" s" 256 8 rshift .\n=> 1" meta! drop
s" lroll" s" description" s" text" s" Bitwise rotate left (circular shift)" meta! drop
s" lroll" s" stack-effect" s" text" s" ( x u -- x' )" meta! drop
s" lroll" s" category" s" text" s" logic" meta! drop
s" lroll" s" examples" s" code" s" 1 1 lroll .\n=> 2" meta! drop
s" rroll" s" description" s" text" s" Bitwise rotate right (circular shift)" meta! drop
s" rroll" s" stack-effect" s" text" s" ( x u -- x' )" meta! drop
s" rroll" s" category" s" text" s" logic" meta! drop
s" rroll" s" examples" s" code" s" 2 1 rroll .\n=> 1" meta! drop
s" true" s" examples" s" code" s" true .\n=> true" meta! drop
s" false" s" examples" s" code" s" false .\n=> false" meta! drop
s" not" s" examples" s" code" s" true not .\n=> false" meta! drop
s" bool" s" examples" s" code" s" 42 bool .\n=> true" meta! drop

# --- I/O ---

s" ." s" description" s" text" s" Print and consume top of stack" meta! drop
s" ." s" stack-effect" s" text" s" ( x -- )" meta! drop
s" ." s" category" s" text" s" i/o" meta! drop

s" cr" s" description" s" text" s" Print newline" meta! drop
s" cr" s" stack-effect" s" text" s" ( -- )" meta! drop
s" cr" s" category" s" text" s" i/o" meta! drop

s" emit" s" description" s" text" s" Print character from ASCII code" meta! drop
s" emit" s" stack-effect" s" text" s" ( char -- )" meta! drop
s" emit" s" category" s" text" s" i/o" meta! drop

s" space" s" description" s" text" s" Print a space" meta! drop
s" space" s" stack-effect" s" text" s" ( -- )" meta! drop
s" space" s" category" s" text" s" i/o" meta! drop

s" spaces" s" description" s" text" s" Print n spaces" meta! drop
s" spaces" s" stack-effect" s" text" s" ( n -- )" meta! drop
s" spaces" s" category" s" text" s" i/o" meta! drop

s" words" s" description" s" text" s" List all dictionary words" meta! drop
s" words" s" stack-effect" s" text" s" ( -- )" meta! drop
s" words" s" category" s" text" s" i/o" meta! drop

s" ." s" examples" s" code" s" 42 .\n=> 42" meta! drop
s" cr" s" examples" s" code" s" 42 . cr 99 .\n=> 42\n=> 99" meta! drop
s" emit" s" examples" s" code" s" 65 emit .| <-- ASCII 65|\n=> A<-- ASCII 65" meta! drop
s" space" s" examples" s" code" s" 1 . space 2 .\n=> 1 2" meta! drop
s" spaces" s" examples" s" code" s" 10 spaces 42 ." meta! drop
s" words" s" examples" s" code" s" words" meta! drop

# --- Handler words: compiling ---

s" :" s" description" s" text" s" Begin colon definition" meta! drop
s" :" s" stack-effect" s" text" s" ( -- )" meta! drop
s" :" s" category" s" text" s" compiling" meta! drop
s" :" s" word-type" s" text" s" interpret-only" meta! drop
s" :" s" examples" s" code" s" : my-double dup + ;\n21 my-double .\n=> 42 " meta! drop

s" ;" s" description" s" text" s" End colon definition" meta! drop
s" ;" s" stack-effect" s" text" s" ( -- )" meta! drop
s" ;" s" category" s" text" s" compiling" meta! drop
s" ;" s" word-type" s" text" s" compile-only" meta! drop
s" ;" s" examples" s" code" s" : my-square dup * ;\n3 my-square .\n=> 9 " meta! drop

s" does>" s" description" s" text" s" Set runtime behavior for CREATE'd words" meta! drop
s" does>" s" stack-effect" s" text" s" ( -- )" meta! drop
s" does>" s" category" s" text" s" compiling" meta! drop
s" does>" s" word-type" s" text" s" compile-only" meta! drop
s" does>" s" examples" s" code" s" : my-const create , does> @ ;\n99 my-const bottles\nbottles .\n=> 99 " meta! drop

# --- Handler words: I/O ---

s| ."|  s" description" s" text" s" Print string literal (interpret/compile)" meta! drop
s| ."|  s" stack-effect" s" text" s" ( -- )" meta! drop
s| ."|  s" category" s" text" s" i/o" meta! drop
s| ."|  s" word-type" s" text" s" both" meta! drop
s| ."|  s" examples" s" code" s| ." Hello!"\n=> Hello!| meta! drop

s| s"|  s" description" s" text" s" Create heap string literal (interpret/compile)" meta! drop
s| s"|  s" stack-effect" s" text" s" ( -- str )" meta! drop
s| s"|  s" category" s" text" s" string" meta! drop
s| s"|  s" word-type" s" text" s" both" meta! drop
s| s"|  s" examples" s" code" s| s" hello" type\n=> hello| meta! drop

s" .|" s" description" s" text" s" Print string literal with escape processing" meta! drop
s" .|" s" stack-effect" s" text" s" ( -- )" meta! drop
s" .|" s" category" s" text" s" i/o" meta! drop
s" .|" s" word-type" s" text" s" both" meta! drop

s" s|" s" description" s" text" s" Push string literal with escape processing" meta! drop
s" s|" s" stack-effect" s" text" s" ( -- str )" meta! drop
s" s|" s" category" s" text" s" string" meta! drop
s" s|" s" word-type" s" text" s" both" meta! drop

# --- Handler words: control flow ---

s" if" s" description" s" text" s" Conditional branch (compile-only). Requires Boolean on TOS." meta! drop
s" if" s" stack-effect" s" text" s" ( bool -- )" meta! drop
s" if" s" category" s" text" s" control" meta! drop
s" if" s" word-type" s" text" s" compile-only" meta! drop
s" if" s" examples" s" code" s" : my-abs   dup 0< if negate then ;\n-5 my-abs .\n=> 5 " meta! drop

s" else" s" description" s" text" s" Alternative branch (compile-only)" meta! drop
s" else" s" stack-effect" s" text" s" ( -- )" meta! drop
s" else" s" category" s" text" s" control" meta! drop
s" else" s" word-type" s" text" s" compile-only" meta! drop
s" else" s" examples" s" code" s" : my-sign   dup 0> if drop 1 else 0< if -1 else 0 then then ;\n42 my-sign .\n=> 1 " meta! drop

s" then" s" description" s" text" s" End conditional (compile-only)" meta! drop
s" then" s" stack-effect" s" text" s" ( -- )" meta! drop
s" then" s" category" s" text" s" control" meta! drop
s" then" s" word-type" s" text" s" compile-only" meta! drop
s" then" s" examples" s" code" s" : my-abs   dup 0< if negate then ;\n-5 my-abs .\n=> 5 " meta! drop

s" do" s" description" s" text" s" Begin counted loop (compile-only)" meta! drop
s" do" s" stack-effect" s" text" s" ( limit start -- )" meta! drop
s" do" s" category" s" text" s" control" meta! drop
s" do" s" word-type" s" text" s" compile-only" meta! drop
s" do" s" examples" s" code" s" : my-sum   0 swap 1 + 0 do i + loop ;\n10 my-sum .\n=> 55 " meta! drop

s" loop" s" description" s" text" s" Increment and loop (compile-only)" meta! drop
s" loop" s" stack-effect" s" text" s" ( -- )" meta! drop
s" loop" s" category" s" text" s" control" meta! drop
s" loop" s" word-type" s" text" s" compile-only" meta! drop
s" loop" s" examples" s" code" s" : my-sum   0 swap 1 + 0 do i + loop ;\n10 my-sum .\n=> 55 " meta! drop

s" +loop" s" description" s" text" s" Add increment and loop (compile-only)" meta! drop
s" +loop" s" stack-effect" s" text" s" ( n -- )" meta! drop
s" +loop" s" category" s" text" s" control" meta! drop
s" +loop" s" word-type" s" text" s" compile-only" meta! drop
s" +loop" s" examples" s" code" s" : my-evens   10 0 do i . 2 +loop ;\nmy-evens\n=> 0 2 4 6 8 " meta! drop

s" i" s" description" s" text" s" Push current loop index (compile-only)" meta! drop
s" i" s" stack-effect" s" text" s" ( -- n )" meta! drop
s" i" s" category" s" text" s" control" meta! drop
s" i" s" word-type" s" text" s" compile-only" meta! drop
s" i" s" examples" s" code" s" : my-squares   5 0 do i dup * . loop ;\nmy-squares\n=> 0 1 4 9 16 " meta! drop

s" j" s" description" s" text" s" Push outer loop index (compile-only)" meta! drop
s" j" s" stack-effect" s" text" s" ( -- n )" meta! drop
s" j" s" category" s" text" s" control" meta! drop
s" j" s" word-type" s" text" s" compile-only" meta! drop
s" j" s" examples" s" code" s" : my-pairs   3 0 do 3 0 do j . i . loop loop ;\nmy-pairs\n=> 0 0 0 1 0 2 1 0 1 1 1 2 2 0 2 1 2 2 " meta! drop

s" begin" s" description" s" text" s" Begin indefinite loop (compile-only)" meta! drop
s" begin" s" stack-effect" s" text" s" ( -- )" meta! drop
s" begin" s" category" s" text" s" control" meta! drop
s" begin" s" word-type" s" text" s" compile-only" meta! drop
s" begin" s" examples" s" code" s" : my-countdown   begin dup while dup . 1 - repeat drop ;\n5 my-countdown\n=> 5 4 3 2 1 " meta! drop

s" until" s" description" s" text" s" Loop until true (compile-only). Requires Boolean on TOS." meta! drop
s" until" s" stack-effect" s" text" s" ( bool -- )" meta! drop
s" until" s" category" s" text" s" control" meta! drop
s" until" s" word-type" s" text" s" compile-only" meta! drop
s" until" s" examples" s" code" s" : my-countup   0 begin 1 + dup . dup 5 = until drop ;\nmy-countup\n=> 1 2 3 4 5 " meta! drop

s" while" s" description" s" text" s" Test and continue loop (compile-only). Requires Boolean on TOS." meta! drop
s" while" s" stack-effect" s" text" s" ( bool -- )" meta! drop
s" while" s" category" s" text" s" control" meta! drop
s" while" s" word-type" s" text" s" compile-only" meta! drop
s" while" s" examples" s" code" s" : my-countdown   begin dup while dup . 1 - repeat drop ;\n5 my-countdown\n=> 5 4 3 2 1 " meta! drop

s" repeat" s" description" s" text" s" End begin/while loop (compile-only)" meta! drop
s" repeat" s" stack-effect" s" text" s" ( -- )" meta! drop
s" repeat" s" category" s" text" s" control" meta! drop
s" repeat" s" word-type" s" text" s" compile-only" meta! drop
s" repeat" s" examples" s" code" s" : my-countdown   begin dup while dup . 1 - repeat drop ;\n5 my-countdown\n=> 5 4 3 2 1 " meta! drop

s" again" s" description" s" text" s" Unconditional loop back to begin (compile-only)" meta! drop
s" again" s" stack-effect" s" text" s" ( -- )" meta! drop
s" again" s" category" s" text" s" control" meta! drop
s" again" s" word-type" s" text" s" compile-only" meta! drop
s" again" s" examples" s" code" s" : my-loop   0 begin dup . 1 + dup 5 = if drop exit then again ;\nmy-loop\n=> 0 1 2 3 4 " meta! drop

