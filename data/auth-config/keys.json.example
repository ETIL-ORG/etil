{
  "jwt_private_key_file": "/etc/etil/jwt-signing.key",
  "jwt_public_key_file": "/etc/etil/jwt-signing.pub",
  "jwt_ttl_seconds": 86400,
  "providers": {
    "github": {
      "enabled": true,
      "client_id": "Iv1.your_github_client_id"
    },
    "google": {
      "enabled": true,
      "client_id": "123456789.apps.googleusercontent.com",
      "client_secret": "GOCSPX-your_secret"
    }
  }
}
